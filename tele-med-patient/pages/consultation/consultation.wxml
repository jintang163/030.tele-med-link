<view class="consultation-page">
  <view class="video-container">
    <live-player
      class="remote-video"
      src="{{remoteVideoUrl}}"
      mode="RTC"
      autoplay
      bindstatechange="onRemotePlayerStateChange"
      wx:if="{{remoteVideoUrl}}"
    ></live-player>

    <view class="remote-placeholder" wx:else>
      <text class="placeholder-text">等待医生接入...</text>
    </view>

    <live-pusher
      class="local-video"
      url="{{localVideoUrl}}"
      mode="RTC"
      muted="{{isMuted}}"
      enable-camera="{{!isCameraOff}}"
      auto-focus
      bindstatechange="onLocalPusherStateChange"
      wx:if="{{localVideoUrl}}"
    ></live-pusher>

    <view class="local-placeholder" wx:else>
      <text>本地摄像头</text>
    </view>
  </view>

  <view class="consultation-info">
    <text class="info-text">会诊号：{{consultationNo}}</text>
    <text class="info-text status-text">状态：{{statusText}}</text>
  </view>

  <view class="control-bar">
    <view class="control-btn" bindtap="toggleMute">
      <view class="control-icon {{isMuted ? 'active' : ''}}">
        <text>{{isMuted ? '🔇' : '🎤'}}</text>
      </view>
      <text class="control-label">{{isMuted ? '已静音' : '静音'}}</text>
    </view>

    <view class="control-btn" bindtap="toggleCamera">
      <view class="control-icon {{isCameraOff ? 'active' : ''}}">
        <text>{{isCameraOff ? '📵' : '📷'}}</text>
      </view>
      <text class="control-label">{{isCameraOff ? '已关闭' : '摄像头'}}</text>
    </view>

    <view class="control-btn" bindtap="switchCamera">
      <view class="control-icon">
        <text>🔄</text>
      </view>
      <text class="control-label">翻转</text>
    </view>

    <view class="control-btn btn-end" bindtap="endConsultation">
      <view class="control-icon">
        <text>📞</text>
      </view>
      <text class="control-label">结束</text>
    </view>
  </view>

  <view class="chat-panel">
    <view class="chat-header" bindtap="toggleChat">
      <text class="chat-title">消息</text>
      <text class="chat-toggle">{{showChat ? '▼' : '▲'}}</text>
    </view>

    <view class="chat-body" wx:if="{{showChat}}">
      <scroll-view class="chat-messages" scroll-y scroll-into-view="{{scrollToId}}">
        <view class="message-item {{item.fromSelf ? 'self' : 'other'}}" wx:for="{{chatMessages}}" wx:key="index" id="msg-{{index}}">
          <view class="message-bubble">
            <text>{{item.content}}</text>
          </view>
          <text class="message-time">{{item.time}}</text>
        </view>
      </scroll-view>

      <view class="chat-input-bar">
        <input
          class="chat-input"
          placeholder="输入消息..."
          value="{{inputMessage}}"
          bindinput="onInputChange"
          confirm-type="send"
          bindconfirm="sendMessage"
        />
        <view class="chat-send-btn" bindtap="sendMessage">
          <text>发送</text>
        </view>
      </view>
    </view>
  </view>
</view>
