.consultation-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #000;
}

.video-container {
  position: relative;
  width: 100%;
  height: 500rpx;
  background: #111;
}

.remote-video {
  width: 100%;
  height: 100%;
}

.remote-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.placeholder-text {
  color: #999;
  font-size: 28rpx;
}

.local-video {
  position: absolute;
  right: 16rpx;
  top: 16rpx;
  width: 200rpx;
  height: 280rpx;
  border-radius: 12rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.3);
  z-index: 10;
}

.local-placeholder {
  position: absolute;
  right: 16rpx;
  top: 16rpx;
  width: 200rpx;
  height: 280rpx;
  border-radius: 12rpx;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 22rpx;
  z-index: 10;
}

.consultation-info {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 24rpx;
  background: #1a1a1a;
}

.info-text {
  color: #ccc;
  font-size: 24rpx;
}

.status-text {
  color: #52c41a;
}

.control-bar {
  display: flex;
  justify-content: space-around;
  padding: 24rpx 0;
  background: #1a1a1a;
  border-top: 1rpx solid #333;
}

.control-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.control-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #333;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  margin-bottom: 8rpx;
}

.control-icon.active {
  background: #ff4d4f;
}

.control-label {
  color: #ccc;
  font-size: 22rpx;
}

.btn-end .control-icon {
  background: #ff4d4f;
}

.btn-end .control-label {
  color: #ff4d4f;
}

.chat-panel {
  flex: 1;
  display: flex;
  flex-direction: column;
  background: #f5f5f5;
  border-top-left-radius: 24rpx;
  border-top-right-radius: 24rpx;
  overflow: hidden;
}

.chat-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  background: #fff;
  border-bottom: 1rpx solid #eee;
}

.chat-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.chat-toggle {
  font-size: 22rpx;
  color: #999;
}

.chat-body {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-height: 0;
}

.chat-messages {
  flex: 1;
  padding: 16rpx 24rpx;
  height: 300rpx;
}

.message-item {
  margin-bottom: 20rpx;
  display: flex;
  flex-direction: column;
}

.message-item.self {
  align-items: flex-end;
}

.message-item.other {
  align-items: flex-start;
}

.message-bubble {
  max-width: 70%;
  padding: 16rpx 20rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  word-break: break-all;
}

.message-item.self .message-bubble {
  background: #1890ff;
  color: #fff;
}

.message-item.other .message-bubble {
  background: #fff;
  color: #333;
}

.message-time {
  font-size: 20rpx;
  color: #999;
  margin-top: 4rpx;
}

.chat-input-bar {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background: #fff;
  border-top: 1rpx solid #eee;
}

.chat-input {
  flex: 1;
  height: 64rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
}

.chat-send-btn {
  margin-left: 16rpx;
  padding: 12rpx 32rpx;
  background: #1890ff;
  color: #fff;
  border-radius: 8rpx;
  font-size: 28rpx;
}
