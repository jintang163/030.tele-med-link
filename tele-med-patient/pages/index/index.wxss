.user-header {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  margin-right: 24rpx;
  background: #e8e8e8;
}

.user-info {
  display: flex;
  flex-direction: column;
}

.user-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.user-id {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.action-cards {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.action-card {
  flex: 0 0 calc(50% - 12rpx);
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
  margin-bottom: 16rpx;
  box-sizing: border-box;
}

.card-immediate {
  border-left: 8rpx solid #1890ff;
}

.card-appointment {
  border-left: 8rpx solid #52c41a;
}

.card-cross-campus {
  border-left: 8rpx solid #722ed1;
}

.card-list {
  border-left: 8rpx solid #fa8c16;
}

.action-icon {
  font-size: 56rpx;
  margin-right: 20rpx;
}

.action-text {
  display: flex;
  flex-direction: column;
}

.action-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.action-desc {
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
}

.section-header {
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.consultation-item {
  padding: 24rpx;
}

.consultation-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.consultation-no {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.consultation-status {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  color: #fff;
}

.status-0 {
  background: #faad14;
}

.status-1 {
  background: #1890ff;
}

.status-2 {
  background: #52c41a;
}

.status-3 {
  background: #ff4d4f;
}

.consultation-body {
  display: flex;
  flex-direction: column;
}

.consultation-doctor {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.consultation-time {
  font-size: 24rpx;
  color: #999;
}

.empty-tip {
  text-align: center;
  padding: 80rpx 0;
  color: #999;
  font-size: 28rpx;
}

.campus-selector {
  background: linear-gradient(135deg, #1890ff 0%, #40a9ff 100%);
  border-radius: 16rpx;
  padding: 24rpx 32rpx;
  margin-bottom: 24rpx;
}

.campus-info {
  display: flex;
  align-items: center;
  color: #fff;
}

.campus-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
}

.campus-name {
  flex: 1;
  font-size: 32rpx;
  font-weight: bold;
}

.campus-arrow {
  font-size: 24rpx;
  opacity: 0.8;
}

.campus-picker-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 999;
}

.campus-picker {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  z-index: 1000;
  padding-bottom: env(safe-area-inset-bottom);
}

.picker-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.picker-cancel {
  font-size: 28rpx;
  color: #999;
}

.picker-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.picker-confirm {
  font-size: 28rpx;
  color: #1890ff;
  font-weight: bold;
}

.picker-body {
  padding: 32rpx;
}

.picker-column {
  margin-bottom: 24rpx;
}

.column-title {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
  display: block;
}

.picker-item {
  background: #f5f7fa;
  border-radius: 8rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: #333;
}
