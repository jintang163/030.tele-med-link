<view class="container">
  <view class="campus-selector" bindtap="showCampusPicker">
    <view class="campus-info">
      <text class="campus-icon">🏥</text>
      <text class="campus-name">{{campusName || '请选择院区'}}</text>
      <text class="campus-arrow">▼</text>
    </view>
  </view>

  <view class="user-header">
    <image class="avatar" src="{{userInfo.avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill"></image>
    <view class="user-info">
      <text class="user-name">{{userInfo.nickName || '未登录'}}</text>
      <text class="user-id" wx:if="{{patientId}}">患者编号：{{patientId}}</text>
    </view>
  </view>

  <view class="action-cards">
    <view class="action-card card-immediate" bindtap="startImmediateConsultation">
      <view class="action-icon">📹</view>
      <view class="action-text">
        <text class="action-title">立即会诊</text>
        <text class="action-desc">发起即时视频会诊</text>
      </view>
    </view>

    <view class="action-card card-appointment" bindtap="navigateToAppointment">
      <view class="action-icon">📅</view>
      <view class="action-text">
        <text class="action-title">预约会诊</text>
        <text class="action-desc">预约未来时段会诊</text>
      </view>
    </view>

    <view class="action-card card-cross-campus" bindtap="navigateToCrossCampus">
      <view class="action-icon">🏥</view>
      <view class="action-text">
        <text class="action-title">跨院区会诊</text>
        <text class="action-desc">预约其他院区专家</text>
      </view>
    </view>

    <view class="action-card card-list" bindtap="navigateToCrossCampusList">
      <view class="action-icon">📋</view>
      <view class="action-text">
        <text class="action-title">我的申请</text>
        <text class="action-desc">查看跨院区申请记录</text>
      </view>
    </view>

    <view class="action-card card-playback" bindtap="navigateToVideoPlayback">
      <view class="action-icon">🎬</view>
      <view class="action-text">
        <text class="action-title">录制回放</text>
        <text class="action-desc">查看会诊视频录制</text>
      </view>
    </view>
  </view>

  <view class="section-header">
    <text class="section-title">我的会诊记录</text>
  </view>

  <view class="consultation-list" wx:if="{{recentConsultations.length > 0}}">
    <view class="card consultation-item" wx:for="{{recentConsultations}}" wx:key="id" bindtap="viewConclusion" data-id="{{item.id}}">
      <view class="consultation-header">
        <text class="consultation-no">{{item.consultationNo}}</text>
        <text class="consultation-status status-{{item.status}}">{{item.statusText}}</text>
      </view>
      <view class="consultation-body">
        <text class="consultation-doctor">会诊医生：{{item.doctorName}}</text>
        <text class="consultation-time">{{item.createTime}}</text>
      </view>
    </view>
  </view>

  <view class="empty-tip" wx:else>
    <text>暂无会诊记录</text>
  </view>

  <view class="campus-picker-mask" wx:if="{{showCampusPicker}}" bindtap="hideCampusPicker"></view>
  <view class="campus-picker" wx:if="{{showCampusPicker}}">
    <view class="picker-header">
      <text class="picker-cancel" bindtap="hideCampusPicker">取消</text>
      <text class="picker-title">选择院区</text>
      <text class="picker-confirm" bindtap="confirmCampusSelection">确定</text>
    </view>
    <view class="picker-body">
      <view class="picker-column">
        <text class="column-title">医院</text>
        <picker mode="selector" range="{{hospitals}}" range-key="name" value="{{selectedHospitalIndex}}" bindchange="onHospitalChange">
          <view class="picker-item">{{hospitalName || '请选择医院'}}</view>
        </picker>
      </view>
      <view class="picker-column">
        <text class="column-title">院区</text>
        <picker mode="selector" range="{{campuses}}" range-key="name" value="{{selectedCampusIndex}}" bindchange="onCampusChange">
          <view class="picker-item">{{campusName || '请选择院区'}}</view>
        </picker>
      </view>
    </view>
  </view>
</view>
