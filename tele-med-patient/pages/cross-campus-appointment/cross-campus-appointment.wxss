.container {
  padding: 24rpx;
  background: #f5f7fa;
  min-height: 100vh;
}

.step-indicator {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx 16rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.step {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.step-num {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #e0e0e0;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.step.active .step-num {
  background: #722ed1;
}

.step-text {
  font-size: 22rpx;
  color: #999;
}

.step.active .step-text {
  color: #722ed1;
  font-weight: bold;
}

.step-line {
  flex: 1;
  height: 4rpx;
  background: #e0e0e0;
  margin: 0 8rpx;
  margin-bottom: 30rpx;
}

.step-line.active {
  background: #722ed1;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.card-title {
  display: flex;
  align-items: center;
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 32rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.title-icon {
  margin-right: 12rpx;
  font-size: 36rpx;
}

.group-label {
  font-size: 28rpx;
  color: #666;
  font-weight: 600;
  margin-bottom: 16rpx;
  margin-top: 8rpx;
}

.campus-group {
  margin-bottom: 24rpx;
}

.source-campus {
  background: linear-gradient(135deg, #1890ff 0%, #40a9ff 100%);
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 8rpx;
}

.campus-badge {
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
}

.campus-item {
  display: flex;
  align-items: center;
  border: 2rpx solid #f0f0f0;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  transition: all 0.2s;
}

.campus-item.selected {
  border-color: #722ed1;
  background: #f9f0ff;
}

.campus-check {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  border: 2rpx solid #d9d9d9;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.campus-item.selected .campus-check {
  background: #722ed1;
  border-color: #722ed1;
  position: relative;
}

.campus-item.selected .campus-check::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 18rpx;
  height: 10rpx;
  border-left: 3rpx solid #fff;
  border-bottom: 3rpx solid #fff;
  transform: translate(-50%, -60%) rotate(-45deg);
}

.campus-detail {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.campus-name {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 4rpx;
}

.campus-addr {
  font-size: 24rpx;
  color: #999;
}

.campus-tags {
  display: flex;
  align-items: center;
  background: #f5f7fa;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 24rpx;
}

.tag-info {
  background: #e6f7ff !important;
  color: #1890ff !important;
  font-size: 26rpx !important;
  padding: 8rpx 20rpx !important;
  border-radius: 8rpx;
}

.tag-warn {
  background: #fff7e6 !important;
  color: #fa8c16 !important;
  font-size: 26rpx !important;
  padding: 8rpx 20rpx !important;
  border-radius: 8rpx;
}

.arrow {
  margin: 0 16rpx;
  color: #999;
  font-size: 28rpx;
}

.dept-filter {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.dept-input {
  flex: 1;
  background: #f5f7fa;
  border-radius: 8rpx;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
}

.btn-filter {
  background: #722ed1 !important;
  color: #fff !important;
  font-size: 26rpx !important;
  padding: 0 24rpx !important;
}

.doctor-group {
  margin-bottom: 24rpx;
}

.doctor-item {
  display: flex;
  align-items: center;
  border: 2rpx solid #f0f0f0;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  transition: all 0.2s;
}

.doctor-item.selected {
  border-color: #722ed1;
  background: #f9f0ff;
}

.doctor-check {
  width: 36rpx;
  height: 36rpx;
  border-radius: 6rpx;
  border: 2rpx solid #d9d9d9;
  margin-right: 20rpx;
  flex-shrink: 0;
  color: transparent;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: bold;
}

.doctor-item.selected .doctor-check {
  background: #722ed1;
  border-color: #722ed1;
  color: #fff;
}

.doctor-info {
  flex: 1;
}

.doctor-row {
  display: flex;
  align-items: center;
  margin-bottom: 6rpx;
}

.doctor-name {
  font-size: 30rpx;
  color: #333;
  font-weight: 600;
  margin-right: 12rpx;
}

.doctor-title {
  font-size: 24rpx;
  color: #722ed1;
  background: #f9f0ff;
  padding: 2rpx 12rpx;
  border-radius: 6rpx;
}

.doctor-dept {
  font-size: 26rpx;
  color: #666;
  margin-right: 8rpx;
}

.doctor-specialty {
  font-size: 24rpx;
  color: #999;
}

.empty-tip {
  padding: 60rpx 0;
  text-align: center;
  color: #999;
  font-size: 28rpx;
}

.btn-row {
  display: flex;
  gap: 20rpx;
  margin-top: 32rpx;
}

.btn-primary {
  flex: 1;
  background: linear-gradient(135deg, #722ed1 0%, #9254de 100%) !important;
  color: #fff !important;
  font-size: 30rpx !important;
  border-radius: 12rpx !important;
  padding: 20rpx 0 !important;
}

.btn-primary[disabled] {
  background: #d9d9d9 !important;
  color: #fff !important;
}

.btn-secondary {
  flex: 1;
  background: #f5f7fa !important;
  color: #666 !important;
  font-size: 30rpx !important;
  border-radius: 12rpx !important;
  padding: 20rpx 0 !important;
}

.date-picker-row {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.date-picker-row .label {
  font-size: 28rpx;
  color: #666;
  margin-right: 16rpx;
}

.date-picker {
  flex: 1;
  background: #f5f7fa;
  border-radius: 8rpx;
  padding: 20rpx 24rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 28rpx;
  color: #333;
}

.picker-arrow {
  color: #999;
  font-size: 24rpx;
}

.doctor-summary {
  display: flex;
  align-items: center;
  background: #f9f0ff;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  font-size: 28rpx;
  color: #722ed1;
  font-weight: 500;
}

.dept-tag {
  margin-left: 16rpx;
  font-size: 24rpx;
  background: #fff;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  color: #722ed1;
}

.time-slots {
  display: flex;
  gap: 20rpx;
  margin-bottom: 16rpx;
}

.slot-item {
  flex: 1;
  border: 2rpx solid #f0f0f0;
  border-radius: 12rpx;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  transition: all 0.2s;
}

.slot-item.selected {
  border-color: #722ed1;
  background: #f9f0ff;
}

.slot-item.disabled {
  opacity: 0.6;
  background: #fafafa;
}

.slot-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.slot-range {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.status-available {
  font-size: 24rpx;
  color: #52c41a;
  background: #f6ffed;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.status-full {
  font-size: 24rpx;
  color: #ff4d4f;
  background: #fff1f0;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.info-list {
  margin-bottom: 24rpx;
}

.info-row {
  display: flex;
  align-items: flex-start;
  padding: 16rpx 0;
  border-bottom: 2rpx solid #f5f5f5;
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  width: 160rpx;
  font-size: 28rpx;
  color: #999;
  flex-shrink: 0;
}

.info-value {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.desc-row {
  flex-direction: column;
}

.desc-row .info-label {
  width: auto;
  margin-bottom: 12rpx;
}

.desc-textarea {
  width: 100%;
  background: #f5f7fa;
  border-radius: 8rpx;
  padding: 20rpx;
  font-size: 28rpx;
  color: #333;
  min-height: 160rpx;
  box-sizing: border-box;
}

.tip-box {
  background: #fffbe6;
  border: 2rpx solid #ffe58f;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.tip-title {
  display: block;
  font-size: 28rpx;
  color: #d46b08;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.tip-text {
  display: block;
  font-size: 24rpx;
  color: #873800;
  line-height: 1.8;
}
