.detail-card {
  padding: 32rpx 24rpx;
}

.detail-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 28rpx;
}

.detail-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.detail-row:last-child {
  border-bottom: none;
}

.detail-label {
  font-size: 28rpx;
  color: #999;
}

.detail-value {
  font-size: 28rpx;
  color: #333;
}

.status-0 {
  color: #faad14;
}

.status-1 {
  color: #1890ff;
}

.status-2 {
  color: #52c41a;
}

.status-3 {
  color: #ff4d4f;
}

.conclusion-card {
  padding: 32rpx 24rpx;
}

.conclusion-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
}

.conclusion-content {
  padding: 24rpx;
  background: #f8f8f8;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  min-height: 120rpx;
}

.conclusion-file {
  display: flex;
  align-items: center;
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #f0f0f0;
}

.file-label {
  font-size: 28rpx;
  color: #999;
  margin-right: 12rpx;
}

.file-link {
  color: #1890ff;
  font-size: 28rpx;
}

.empty-conclusion {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 80rpx 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

.signature-card {
  padding: 32rpx 24rpx;
}

.signature-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
}

.signature-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.signature-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 20rpx;
  background: #f8f8f8;
  border-radius: 8rpx;
}

.sig-doctor {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.sig-status {
  font-size: 24rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.sig-signed {
  color: #52c41a;
  background: #f6ffed;
  border: 1rpx solid #b7eb8f;
}

.sig-pending {
  color: #faad14;
  background: #fffbe6;
  border: 1rpx solid #ffe58f;
}

.pdf-download-area {
  margin-top: 16rpx;
}

.pdf-btn {
  width: 100%;
  font-size: 30rpx;
}

.pdf-waiting {
  text-align: center;
  padding: 24rpx 0;
}

.waiting-text {
  font-size: 24rpx;
  color: #999;
}

.diagnosis-card {
  padding: 28rpx 24rpx;
  background: linear-gradient(180deg, #f6faff 0%, #ffffff 100%);
}

.diagnosis-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.diagnosis-header .diagnosis-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #2f54eb;
}

.diagnosis-disclaimer-tag {
  font-size: 22rpx;
  color: #d46b08;
  background: #fff7e6;
  padding: 4rpx 14rpx;
  border-radius: 16rpx;
}

.diagnosis-disclaimer-warning {
  font-size: 24rpx;
  color: #8c4d12;
  background: #fffbe6;
  border: 1rpx solid #ffe58f;
  padding: 14rpx 16rpx;
  border-radius: 8rpx;
  margin-bottom: 20rpx;
  line-height: 1.5;
}

.diagnosis-primary {
  background: #ffffff;
  border: 2rpx solid #91caff;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.primary-label {
  font-size: 24rpx;
  color: #595959;
  margin-bottom: 8rpx;
}

.primary-disease-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #1d39c4;
  margin-bottom: 10rpx;
}

.primary-confidence {
  display: inline-block;
  font-size: 26rpx;
  font-weight: 600;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
}

.confidence-high {
  color: #389e0d;
  background: #f6ffed;
  border: 1rpx solid #b7eb8f;
}

.confidence-mid {
  color: #d46b08;
  background: #fff7e6;
  border: 1rpx solid #ffd591;
}

.confidence-low {
  color: #cf1322;
  background: #fff1f0;
  border: 1rpx solid #ffa39e;
}

.secondary-diseases {
  margin-bottom: 20rpx;
}

.secondary-label,
.section-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #262626;
  margin-bottom: 12rpx;
}

.secondary-list {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.secondary-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #ffffff;
  border: 1rpx solid #e8e8e8;
  border-radius: 8rpx;
  padding: 14rpx 16rpx;
}

.secondary-item .disease-name {
  font-size: 28rpx;
  color: #262626;
}

.secondary-item .disease-conf {
  font-size: 26rpx;
  color: #595959;
  font-weight: 600;
}

.symptoms-section,
.tests-section {
  margin-bottom: 16rpx;
}

.symptom-tags,
.test-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.symptom-tag,
.test-tag {
  font-size: 24rpx;
  padding: 8rpx 18rpx;
  border-radius: 20rpx;
  line-height: 1.4;
}

.symptom-tag {
  color: #c41d7f;
  background: #fff0f6;
  border: 1rpx solid #ffadd2;
}

.test-tag {
  color: #08979c;
  background: #e6fffb;
  border: 1rpx solid #87e8de;
}
