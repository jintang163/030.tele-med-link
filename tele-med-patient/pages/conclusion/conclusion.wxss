.detail-card {
  padding: 32rpx 24rpx;
}

.detail-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 28rpx;
}

.detail-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.detail-row:last-child {
  border-bottom: none;
}

.detail-label {
  font-size: 28rpx;
  color: #999;
}

.detail-value {
  font-size: 28rpx;
  color: #333;
}

.status-0 {
  color: #faad14;
}

.status-1 {
  color: #1890ff;
}

.status-2 {
  color: #52c41a;
}

.status-3 {
  color: #ff4d4f;
}

.conclusion-card {
  padding: 32rpx 24rpx;
}

.conclusion-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
}

.conclusion-content {
  padding: 24rpx;
  background: #f8f8f8;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  min-height: 120rpx;
}

.conclusion-file {
  display: flex;
  align-items: center;
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #f0f0f0;
}

.file-label {
  font-size: 28rpx;
  color: #999;
  margin-right: 12rpx;
}

.file-link {
  color: #1890ff;
  font-size: 28rpx;
}

.empty-conclusion {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 80rpx 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

.signature-card {
  padding: 32rpx 24rpx;
}

.signature-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
}

.signature-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.signature-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 20rpx;
  background: #f8f8f8;
  border-radius: 8rpx;
}

.sig-doctor {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.sig-status {
  font-size: 24rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.sig-signed {
  color: #52c41a;
  background: #f6ffed;
  border: 1rpx solid #b7eb8f;
}

.sig-pending {
  color: #faad14;
  background: #fffbe6;
  border: 1rpx solid #ffe58f;
}

.pdf-download-area {
  margin-top: 16rpx;
}

.pdf-btn {
  width: 100%;
  font-size: 30rpx;
}

.pdf-waiting {
  text-align: center;
  padding: 24rpx 0;
}

.waiting-text {
  font-size: 24rpx;
  color: #999;
}
