.container {
  min-height: 100vh;
  background: #f5f7fa;
  padding: 0;
}

.header {
  background: linear-gradient(135deg, #1890ff, #40a9ff);
  padding: 60rpx 40rpx 80rpx;
  color: #fff;
}

.header-title {
  font-size: 44rpx;
  font-weight: bold;
  margin-bottom: 16rpx;
}

.header-desc {
  font-size: 26rpx;
  opacity: 0.9;
}

.card {
  margin: -40rpx 24rpx 24rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.form-item {
  margin-bottom: 32rpx;
}

.form-label {
  font-size: 28rpx;
  color: #606266;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.form-input {
  width: 100%;
  height: 80rpx;
  padding: 0 24rpx;
  border: 2rpx solid #dcdfe6;
  border-radius: 8rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  background: #fafafa;
}

.form-input:focus {
  border-color: #1890ff;
  background: #fff;
}

.picker-value {
  height: 80rpx;
  line-height: 80rpx;
  padding: 0 24rpx;
  border: 2rpx solid #dcdfe6;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: #303133;
  background: #fafafa;
  position: relative;
}

.picker-arrow {
  position: absolute;
  right: 24rpx;
  color: #c0c4cc;
  font-size: 36rpx;
}

.face-upload-area {
  width: 100%;
  height: 360rpx;
  border: 2rpx dashed #dcdfe6;
  border-radius: 12rpx;
  background: #fafafa;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.face-img {
  width: 100%;
  height: 100%;
}

.face-placeholder {
  text-align: center;
  color: #909399;
}

.placeholder-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.placeholder-text {
  font-size: 26rpx;
}

.tips {
  background: #f0f9ff;
  border-radius: 8rpx;
  padding: 20rpx 24rpx;
  margin: 24rpx 0;
}

.tips-title {
  font-size: 26rpx;
  color: #1890ff;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.tips-item {
  font-size: 24rpx;
  color: #606266;
  line-height: 1.8;
}

.tips-item.remain {
  color: #e6a23c;
  font-weight: 500;
}

.fail-reason {
  background: #fef0f0;
  color: #f56c6c;
  padding: 16rpx 20rpx;
  border-radius: 8rpx;
  font-size: 26rpx;
  margin-bottom: 24rpx;
}

.verify-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
  border-radius: 44rpx;
  margin-top: 16rpx;
}

.privacy-tip {
  text-align: center;
  padding: 30rpx 24rpx;
  font-size: 22rpx;
  color: #909399;
}

.lock-tip {
  text-align: center;
  padding: 40rpx 20rpx;
}

.lock-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.lock-text {
  font-size: 36rpx;
  color: #f56c6c;
  font-weight: bold;
  margin-bottom: 12rpx;
}

.lock-time {
  font-size: 26rpx;
  color: #909399;
  margin-bottom: 20rpx;
}

.lock-desc {
  font-size: 26rpx;
  color: #606266;
  margin-bottom: 32rpx;
}

.contact-btn {
  background: #1890ff;
  color: #fff;
  font-size: 28rpx;
  border-radius: 40rpx;
  padding: 0 60rpx;
  height: 80rpx;
  line-height: 80rpx;
}
