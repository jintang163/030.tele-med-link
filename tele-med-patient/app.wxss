page {
  background: #f5f5f5;
  font-family: -apple-system, sans-serif;
  color: #333;
  font-size: 28rpx;
}

.container {
  padding: 24rpx;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.btn-primary {
  background: #1890ff;
  color: #fff;
  border-radius: 8rpx;
  text-align: center;
  padding: 20rpx;
  font-size: 32rpx;
}

.btn-danger {
  background: #ff4d4f;
  color: #fff;
  border-radius: 8rpx;
  text-align: center;
  padding: 20rpx;
  font-size: 32rpx;
}
